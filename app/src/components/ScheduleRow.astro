---
import Countdown from './Countdown.astro';
import type { Anime } from '../lib/catalog';
interface Props { a: Anime }
const { a } = Astro.props;
const soon = a.nextEp ? a.nextEp.airingAt - Date.now() / 1000 < 3600 : false;
const meta = [a.format, a.studio, a.score ? `${a.score}%` : null].filter(Boolean).join(' · ');
---
<a class="row" href={`/anime/${a.slug}`}>
  <span class="poster"><img src={a.cover} alt="" loading="lazy" decoding="async" width="48" height="64" /></span>
  <span class="main">
    <span class="title">{a.title}</span>
    <span class="meta">{a.english && a.english !== a.title ? a.english : meta}</span>
  </span>
  <span class="genres">{a.genres.slice(0, 2).map((g) => <span class="chip">{g}</span>)}</span>
  {a.nextEp && (
    <span class:list={['cd', { soon }]}>
      <span class="ep mono">EP {a.nextEp.episode}</span>
      {soon && <span class="live-dot" aria-hidden="true"></span>}
      <Countdown airAt={a.nextEp.airingAt} />
    </span>
  )}
</a>

<style>
  .row { display: grid; grid-template-columns: 3rem 1fr auto auto; align-items: center; gap: 1.1rem; padding: 0.7rem 0.85rem; margin-inline: -0.85rem; border-radius: var(--radius); transition: background .14s; }
  .row:hover { background: var(--bg-soft); }
  .poster { width: 3rem; height: 4rem; border-radius: 7px; overflow: hidden; background: var(--bg-soft); flex: none; }
  .poster img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .main { min-width: 0; display: flex; flex-direction: column; gap: 0.2rem; }
  .title { font-weight: 600; font-size: var(--t-md); color: var(--ink); letter-spacing: -0.01em; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .row:hover .title { color: var(--accent); }
  .meta { font-size: var(--t-sm); color: var(--muted); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .genres { display: flex; gap: 0.3rem; }
  .chip { font-size: 0.68rem; color: var(--muted); background: var(--bg-soft); border: 1px solid var(--line); padding: 0.12rem 0.5rem; border-radius: 999px; white-space: nowrap; }
  .cd { display: inline-flex; align-items: center; gap: 0.5rem; white-space: nowrap; font-size: var(--t-sm); color: var(--muted); }
  .cd .ep { color: var(--faint); }
  .live-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--live); box-shadow: 0 0 0 3px color-mix(in srgb, var(--live) 22%, transparent); }
  @media (max-width: 640px) { .row { grid-template-columns: 2.75rem 1fr auto; } .genres { display: none; } }
</style>
