---
import Countdown from './Countdown.astro';
import type { Anime } from '../lib/catalog';
interface Props { a: Anime }
const { a } = Astro.props;
const meta = [a.format, a.episodes ? `${a.episodes} eps` : null, a.year].filter(Boolean).join(' · ');
---
<a class="card" href={`/anime/${a.slug}`}>
  <div class="poster" style={a.color ? `background:${a.color}` : undefined}>
    <img src={a.cover} alt={a.title} loading="lazy" decoding="async" width="230" height="325" />
    {a.score && <span class:list={['score', { hi: a.score >= 75 }]}>{a.score}</span>}
  </div>
  <div class="info">
    <h3 class="title">{a.title}</h3>
    <p class="meta">{meta}</p>
    {a.genres.length > 0 && (
      <div class="genres">{a.genres.slice(0, 2).map((g) => <span class="chip">{g}</span>)}</div>
    )}
    {a.nextEp && (
      <p class="next"><span class="ep mono">EP {a.nextEp.episode}</span> <span class="in">in</span> <Countdown airAt={a.nextEp.airingAt} /></p>
    )}
  </div>
</a>

<style>
  .card { display: flex; flex-direction: column; gap: 0.65rem; }
  .poster { position: relative; aspect-ratio: 23 / 32; border-radius: 12px; overflow: hidden; background: var(--bg-soft); box-shadow: 0 1px 2px rgba(0,0,0,.06); }
  .poster img { width: 100%; height: 100%; object-fit: cover; display: block; transition: transform .25s ease; }
  .card:hover .poster img { transform: scale(1.04); }
  .score { position: absolute; top: 0.5rem; right: 0.5rem; font-family: var(--font-mono); font-size: 0.72rem; font-weight: 700; color: #fff; background: rgba(20,22,28,.78); backdrop-filter: blur(4px); padding: 0.15rem 0.4rem; border-radius: 6px; }
  .score.hi { background: rgba(22,163,74,.9); }
  .info { display: flex; flex-direction: column; gap: 0.3rem; }
  .title { font-size: var(--t-sm); font-weight: 600; color: var(--ink); line-height: 1.25; letter-spacing: -0.01em; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .card:hover .title { color: var(--accent); }
  .meta { font-size: var(--t-xs); color: var(--faint); }
  .genres { display: flex; gap: 0.3rem; flex-wrap: wrap; }
  .chip { font-size: 0.68rem; color: var(--muted); background: var(--bg-soft); border: 1px solid var(--line); padding: 0.1rem 0.45rem; border-radius: 999px; }
  .next { font-size: var(--t-xs); color: var(--muted); display: flex; align-items: baseline; gap: 0.35rem; margin-top: 0.1rem; }
  .next .ep { color: var(--ink); font-weight: 600; }
  .next .in { color: var(--faint); }
</style>
