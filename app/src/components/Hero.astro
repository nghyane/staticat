---
import Countdown from './Countdown.astro';
import type { Anime } from '../lib/catalog';
interface Props { a: Anime; season: string }
const { a, season } = Astro.props;
const meta = [a.format, a.episodes ? `${a.episodes} eps` : null, a.studio].filter(Boolean);
---
<section class="hero">
  <div class="bg">
    {a.banner ? <img src={a.banner} alt="" fetchpriority="high" width="1600" height="500" /> : <div class="bgc" style={`background:${a.color ?? '#6D5BFF'}`}></div>}
  </div>
  <div class="wrap hero-in">
    <p class="eyebrow">Now airing &middot; {season}</p>
    <a class="ht" href={`/anime/${a.slug}`}>{a.title}</a>
    <p class="hmeta">
      {a.score && <span class:list={['score', { hi: a.score >= 75 }]}>{a.score}%</span>}
      {meta.map((m) => <span class="m">{m}</span>)}
    </p>
    <div class="hchips">{a.genres.slice(0, 4).map((g) => <span class="chip">{g}</span>)}</div>
    {a.nextEp && (
      <p class="hcd">
        <span class="ep mono">EP {a.nextEp.episode}</span>
        <span class="in">airs in</span>
        <Countdown airAt={a.nextEp.airingAt} class="big" />
      </p>
    )}
  </div>
</section>

<style>
  .hero { position: relative; min-height: 30rem; display: flex; align-items: flex-end; overflow: hidden; margin-bottom: 3.5rem; }
  .bg { position: absolute; inset: 0; }
  .bg img, .bgc { width: 100%; height: 100%; object-fit: cover; object-position: center 25%; display: block; }
  /* fade banner into the page at the bottom (text reads on light) + soften the right */
  .bg::after {
    content: ''; position: absolute; inset: 0;
    background:
      linear-gradient(to bottom, rgba(10,12,18,.5) 0, transparent 100px),
      linear-gradient(to top, var(--bg) 3%, color-mix(in srgb, var(--bg) 60%, transparent) 36%, transparent 72%),
      linear-gradient(to right, color-mix(in srgb, var(--bg) 30%, transparent), transparent 55%);
  }
  .hero-in { position: relative; padding-bottom: 2.75rem; }
  .eyebrow { color: var(--muted); }
  .ht { display: block; font-family: var(--font-display); font-size: clamp(2.3rem, 5.2vw, 3.5rem); font-weight: 700; letter-spacing: -0.035em; line-height: 1.02; color: var(--ink); max-width: 16ch; margin-top: 0.7rem; transition: color .15s; }
  .ht:hover { color: var(--accent); }
  .hmeta { display: flex; align-items: center; flex-wrap: wrap; gap: 0.6rem; margin-top: 1rem; font-size: var(--t-sm); color: var(--muted); }
  .score { font-family: var(--font-mono); font-weight: 700; color: #fff; background: var(--muted); padding: 0.12rem 0.48rem; border-radius: 6px; }
  .score.hi { background: var(--live); }
  .m + .m::before, .score + .m::before { content: '·'; color: var(--line-2); margin-right: 0.6rem; }
  .hchips { display: flex; flex-wrap: wrap; gap: 0.45rem; margin-top: 1rem; }
  .chip { font-size: var(--t-xs); color: var(--ink); background: color-mix(in srgb, var(--bg) 78%, transparent); backdrop-filter: blur(6px); padding: 0.24rem 0.72rem; border-radius: 999px; }
  .hcd { display: flex; align-items: baseline; gap: 0.55rem; margin-top: 1.5rem; font-size: var(--t-lg); }
  .hcd .ep { color: var(--ink); font-weight: 700; }
  .hcd .in { color: var(--muted); font-size: var(--t-md); }
  .hcd :global(.cd-num.big) { color: var(--accent); font-weight: 700; min-width: 6ch; font-size: var(--t-lg); }
  @media (max-width: 560px) { .hero { min-height: 24rem; } }
</style>
