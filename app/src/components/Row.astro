---
import Countdown from './Countdown.astro';
import type { AiringEntry } from '../data/mock';
interface Props { entry: AiringEntry }
const { entry } = Astro.props;
const live = entry.offsetMin < 60;
// Deterministic cover placeholder (real build hotlinks the AniList cover CDN).
const hue = [...entry.slug].reduce((a, c) => a + c.charCodeAt(0), 0) % 360;
const cover = `linear-gradient(140deg, hsl(${hue} 62% 70%), hsl(${(hue + 38) % 360} 64% 58%))`;
const initial = entry.title.replace(/[^A-Za-z0-9]/g, '').slice(0, 1).toUpperCase();
---
<a class="row" href={`/anime/${entry.slug}`}>
  <span class="cover" style={`background:${cover}`} aria-hidden="true">{initial}</span>
  <span class="main">
    <span class="title">{entry.title}</span>
    <span class="meta">
      <span class="ep">EP {entry.ep}</span>
      <span class="dot-sep">&middot;</span>
      <span class="mono time">{entry.time}</span>
      <span class="dot-sep">&middot;</span>
      <span class="prov">{entry.providers.join(', ')}</span>
    </span>
  </span>
  <span class:list={['cd', { live }]}>
    {live && <span class="live-dot" aria-hidden="true"></span>}
    <Countdown offsetMin={entry.offsetMin} />
  </span>
</a>

<style>
  .row {
    display: grid;
    grid-template-columns: 2.75rem 1fr auto;
    align-items: center;
    gap: 1.1rem;
    padding: 0.9rem 0.85rem;
    margin-inline: -0.85rem;
    border-radius: var(--radius);
    transition: background .14s;
  }
  .row:hover { background: var(--bg-soft); }

  .cover {
    width: 2.75rem; height: 3.75rem;
    border-radius: 8px;
    display: grid; place-items: center;
    font-family: var(--font-display); font-weight: 700; font-size: 1.1rem;
    color: rgba(255,255,255,.92);
    box-shadow: inset 0 0 0 1px rgba(0,0,0,.06);
  }

  .main { min-width: 0; display: flex; flex-direction: column; gap: 0.3rem; }
  .title { font-weight: 600; font-size: var(--t-md); color: var(--ink); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; letter-spacing: -0.01em; }
  .row:hover .title { color: var(--accent); }
  .meta { display: flex; align-items: center; gap: 0.5rem; font-size: var(--t-sm); color: var(--muted); }
  .ep { color: var(--faint); }
  .time { color: var(--muted); }
  .dot-sep { color: var(--line-2); }
  .prov { color: var(--muted); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  .cd { display: inline-flex; align-items: center; gap: 0.5rem; white-space: nowrap; font-size: var(--t-md); color: var(--muted); }
  .live-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--live); box-shadow: 0 0 0 3px color-mix(in srgb, var(--live) 22%, transparent); }

  @media (max-width: 560px) {
    .row { grid-template-columns: 2.5rem 1fr auto; gap: 0.9rem; }
    .meta { flex-wrap: wrap; gap: 0.35rem; }
  }
</style>
