---
import Base from '../layouts/Base.astro';
import ScheduleRow from '../components/ScheduleRow.astro';
import MediaCard from '../components/MediaCard.astro';
import { getAnime, airingNext } from '../lib/catalog';

const all = getAnime();
const airing = airingNext();
const upNext = airing.slice(0, 10);
const trending = all.slice(0, 18);
// Current season = most common (season, year) among airing shows — not the first
// long-runner's debut season.
const counts = new Map<string, number>();
for (const a of airing) if (a.season && a.year) counts.set(`${a.season} ${a.year}`, (counts.get(`${a.season} ${a.year}`) ?? 0) + 1);
const seasonLabel = [...counts.entries()].sort((x, y) => y[1] - x[1])[0]?.[0] ?? 'This season';
---
<Base>
  <div class="wrap">
    <section class="lede">
      <p class="eyebrow">Now airing &middot; {seasonLabel}</p>
      <h1 class="h1">When the next episode airs,<br />and where to watch it.</h1>
      <p class="sub">Live countdowns for {airing.length} currently-airing series, with scores, genres and streaming &mdash; in your local timezone.</p>
    </section>

    {upNext.length > 0 && (
      <section class="block">
        <header class="block-hd"><h2>Up next</h2><span class="eyebrow">{upNext.length} airing soon</span></header>
        <div class="rows">{upNext.map((a) => <ScheduleRow a={a} />)}</div>
      </section>
    )}

    {trending.length > 0 && (
      <section class="block">
        <header class="block-hd"><h2>Trending this season</h2></header>
        <div class="grid">{trending.map((a) => <MediaCard a={a} />)}</div>
      </section>
    )}
  </div>
</Base>

<style>
  .lede { padding-block: 1rem 2.75rem; }
  .h1 { font-family: var(--font-display); font-size: var(--t-2xl); font-weight: 700; line-height: 1.08; letter-spacing: -0.03em; color: var(--ink); }
  .sub { color: var(--muted); margin-top: 1.1rem; max-width: 50ch; font-size: var(--t-md); }
  .block { margin-top: 3.5rem; }
  .block-hd { display: flex; align-items: baseline; justify-content: space-between; padding-bottom: 1rem; border-bottom: 1px solid var(--line); margin-bottom: 1rem; }
  .block-hd h2 { font-family: var(--font-display); font-size: var(--t-lg); font-weight: 700; letter-spacing: -0.02em; }
  .rows { display: flex; flex-direction: column; }
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 1.75rem 1.1rem; }
  @media (max-width: 560px) { .h1 { font-size: var(--t-xl); } .h1 br { display: none; } .grid { grid-template-columns: repeat(auto-fill, minmax(110px, 1fr)); gap: 1.25rem 0.85rem; } }
</style>
