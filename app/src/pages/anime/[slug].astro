---
import Base from '../../layouts/Base.astro';
import Countdown from '../../components/Countdown.astro';
import { getAnime } from '../../lib/catalog';

export function getStaticPaths() {
  return getAnime().map((a) => ({ params: { slug: a.slug }, props: { a } }));
}
const { a } = Astro.props;
const meta = [a.format, a.episodes ? `${a.episodes} episodes` : null, a.season && a.year ? `${a.season} ${a.year}` : null, a.studio].filter(Boolean);
const jsonLd = {
  '@context': 'https://schema.org', '@type': 'TVSeries', name: a.title,
  ...(a.english ? { alternateName: a.english } : {}),
  ...(a.description ? { description: a.description.slice(0, 280) } : {}),
  ...(a.cover ? { image: a.cover } : {}),
  ...(a.score ? { aggregateRating: { '@type': 'AggregateRating', ratingValue: (a.score / 10).toFixed(1), bestRating: 10, ratingCount: 1 } } : {}),
  genre: a.genres,
};
---
<Base title={`${a.title} — where to watch & next episode | Watchdex`} desc={a.description?.slice(0, 155) ?? `When ${a.title} airs next and where to watch it.`} bleed>
  <div class="wrap topbar"><a class="back" href="/">&larr; Schedule</a></div>

  {a.banner && <div class="banner"><img src={a.banner} alt="" width="1280" height="300" /></div>}

  <div class="wrap entity" class:list={[{ hasbanner: a.banner }]}>
    <header class="hero">
      <div class="poster" style={a.color ? `background:${a.color}` : undefined}>
        <img src={a.cover} alt={a.title} width="200" height="283" />
      </div>
      <div class="head">
        <h1 class="h1">{a.title}</h1>
        {a.english && a.english !== a.title && <p class="alt">{a.english}</p>}
        <p class="metaline">
          {a.score && <span class:list={['score', { hi: a.score >= 75 }]}>{a.score}%</span>}
          {meta.map((m) => <span class="m">{m}</span>)}
        </p>
        {a.genres.length > 0 && <div class="genres">{a.genres.map((g) => <span class="chip">{g}</span>)}</div>}
      </div>
    </header>

    <div class="body">
      <div class="facts">
        {a.nextEp && (
          <section class="card">
            <p class="eyebrow">Next episode</p>
            <p class="next-line"><span class="ep mono">EP {a.nextEp.episode}</span> <span class="in">in</span> <Countdown airAt={a.nextEp.airingAt} /></p>
          </section>
        )}
        <section class="card">
          <p class="eyebrow">Where to watch</p>
          {a.streams.length > 0 ? (
            <div class="watch">{a.streams.map((s) => <a class="prov" href={s.url} rel="nofollow noopener" target="_blank">{s.site} &rarr;</a>)}</div>
          ) : (
            <p class="nostream">No streaming links yet.</p>
          )}
        </section>
      </div>

      {a.description && (
        <section class="synopsis">
          <p class="eyebrow">Synopsis</p>
          <p class="desc">{a.description}</p>
        </section>
      )}
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</Base>

<style>
  .topbar { padding-block: 0.25rem; }
  .back { display: inline-flex; align-items: center; gap: 0.35rem; white-space: nowrap; color: var(--muted); font-size: var(--t-sm); }
  .back:hover { color: var(--accent); }

  .banner { position: relative; height: 300px; margin-top: 0.6rem; overflow: hidden; }
  .banner img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .banner::after { content: ''; position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(15,18,25,.12), transparent 35%, var(--bg) 97%); }

  .entity { max-width: var(--col); }
  .entity.hasbanner { margin-top: -140px; position: relative; }

  .hero { display: flex; gap: 2rem; align-items: flex-end; }
  .poster { width: 11rem; flex: none; aspect-ratio: 23/32; border-radius: 16px; overflow: hidden; box-shadow: 0 14px 36px -16px rgba(0,0,0,.4); background: var(--bg-soft); }
  .poster img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .head { min-width: 0; padding-bottom: 0.5rem; }
  .h1 { font-family: var(--font-display); font-size: var(--t-2xl); font-weight: 700; letter-spacing: -0.03em; line-height: 1.04; }
  .alt { color: var(--muted); margin-top: 0.4rem; font-size: var(--t-md); }
  .metaline { display: flex; align-items: center; flex-wrap: wrap; gap: 0.6rem; margin-top: 1rem; font-size: var(--t-sm); color: var(--muted); }
  .score { font-family: var(--font-mono); font-weight: 700; color: #fff; background: var(--muted); padding: 0.1rem 0.45rem; border-radius: 6px; }
  .score.hi { background: var(--live); }
  .m + .m::before, .score + .m::before { content: '·'; color: var(--line-2); margin-right: 0.6rem; }
  .genres { display: flex; flex-wrap: wrap; gap: 0.45rem; margin-top: 0.9rem; }
  .chip { font-size: var(--t-xs); color: var(--muted); background: var(--bg-soft); border: 1px solid var(--line); padding: 0.2rem 0.65rem; border-radius: 999px; }

  .body { margin-top: 3rem; }
  .facts { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; }
  .card { background: var(--bg-soft); border: 1px solid var(--line); border-radius: 14px; padding: 1.15rem 1.3rem; }
  .next-line { display: flex; align-items: baseline; gap: 0.6rem; margin-top: 0.55rem; font-size: var(--t-lg); }
  .next-line .ep { color: var(--ink); font-weight: 700; }
  .next-line .in { color: var(--faint); font-size: var(--t-md); }
  .next-line :global(.cd-num) { color: var(--accent); font-weight: 700; min-width: 6ch; }
  .watch { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.75rem; }
  .prov { border: 1px solid var(--line-2); border-radius: 9px; padding: 0.45rem 0.8rem; font-size: var(--t-sm); font-weight: 500; color: var(--ink); transition: border-color .15s, background .15s, color .15s; }
  .prov:hover { border-color: var(--accent); background: var(--accent-soft); color: var(--accent); }
  .nostream { color: var(--faint); font-size: var(--t-sm); margin-top: 0.75rem; }

  .synopsis { margin-top: 2.5rem; }
  .synopsis .desc { margin-top: 0.7rem; color: var(--muted); line-height: 1.8; max-width: 76ch; font-size: var(--t-md); }

  @media (max-width: 760px) {
    .facts { grid-template-columns: 1fr; }
    .hero { gap: 1.25rem; }
    .poster { width: 7rem; border-radius: 12px; }
    .h1 { font-size: var(--t-xl); }
    .banner { height: 200px; }
    .entity.hasbanner { margin-top: -90px; }
  }
</style>
